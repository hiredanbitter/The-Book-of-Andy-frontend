# ===========================================
# Podcast Transcript Search App
# Environment Variables
# ===========================================

# --- Supabase ---
# Your Supabase project URL (e.g. https://xyzcompany.supabase.co)
SUPABASE_URL=

# Your Supabase service role key (used by the backend for privileged operations)
SUPABASE_SERVICE_ROLE_KEY=

# Your Supabase anon/public key (used by the frontend for client-side auth)
SUPABASE_ANON_KEY=

# --- OpenAI ---
# Your OpenAI API key (used for generating embeddings)
OPENAI_API_KEY=

# --- Frontend ---
# The URL of the backend API (used by the frontend to make API calls)
VITE_API_BASE_URL=http://localhost:8000

# The Supabase URL (used by the frontend for auth)
VITE_SUPABASE_URL=

# The Supabase anon key (used by the frontend for auth)
VITE_SUPABASE_ANON_KEY=

# --- Backend ---
# The port the backend runs on (default: 8000)
BACKEND_PORT=8000
