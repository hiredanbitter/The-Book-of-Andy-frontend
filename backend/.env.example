# ===========================================
# Backend Environment Variables
# ===========================================

# --- Supabase ---
# Your Supabase project URL (e.g. https://xyzcompany.supabase.co)
SUPABASE_URL=

# Your Supabase service role key (used for privileged operations)
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI ---
# Your OpenAI API key (used for generating embeddings)
OPENAI_API_KEY=

# --- CORS ---
# Comma-separated list of allowed origins for CORS requests.
# If not set, defaults to http://localhost:5173 (local dev frontend).
# Example: http://localhost:5173,https://your-production-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Lambda Cloud (GPU pipeline) ---
# Lambda Cloud API key (for launching/terminating GPU instances)
LAMBDA_API_KEY=

# Name of the SSH key registered in the Lambda Cloud dashboard
LAMBDA_SSH_KEY_NAME=

# Read-only GitHub personal access token for cloning the repo on the GPU instance
GITHUB_DEPLOY_TOKEN=
